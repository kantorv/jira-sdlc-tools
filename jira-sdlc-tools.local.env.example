# GITHUB SETTINGS (machine-specific)
WORKTREES_DIR=../myapp-worktrees
# Fine-grained GitHub PAT. Secret + machine-specific, so it lives ONLY here in
# the gitignored local.env (never the tracked jira-sdlc-tools.env), like
# JIRA_TOKEN. statuscheck logs gh in with it at session start
# (gh auth login --with-token) and holds that session for the whole
# conversation; if it's missing the gh_auth row FAILs and the run halts. See
# plugins/jira-sdlc/docs/github/GH-PAT-SESSION-LOGIN.md. Placeholder only — never
# commit a real token.
GITHUB_PAT_TOKEN="XXXXXXXXXXXXXXXXXX"

# JIRA DEFAULT SETTINGS 
JIRA_ACCOUNT_URL=your-site.atlassian.net
JIRA_ACCOUNT_EMAIL=you@example.com
# the raw API token value itself — not a path to a token file
JIRA_TOKEN=your-api-token-value

# PER-ROLE JIRA ACCOUNTS (optional) — let each skill act as its own Jira user,
# so the board shows who did what: the assigner filed it, the executor
# implemented it, the reviewer approved it. Each pair is optional and falls back
# to JIRA_ACCOUNT_EMAIL/JIRA_TOKEN above (independently — set only the EMAIL to
# share the default token), so leaving all of this commented out keeps the
# skills working as one account.
#
# The executor's email doubles as the ASSIGNEE: jira-task-assigner puts it on
# every issue it creates, and jira-task-executor refuses to work an issue that
# isn't assigned to it.
#
# Tokens are the raw API token value, never a path to a file — as JIRA_TOKEN.
# See skills/_shared/project-config.md for the machine-global acli side effect
# of switching accounts.
#JIRA_ASSIGNER_EMAIL=assigner@example.com
#JIRA_ASSIGNER_TOKEN=your-assigner-api-token-value
#JIRA_EXECUTOR_EMAIL=executor@example.com
#JIRA_EXECUTOR_TOKEN=your-executor-api-token-value
#JIRA_REVIEWER_EMAIL=reviewer@example.com
#JIRA_REVIEWER_TOKEN=your-reviewer-api-token-value


