# GITHUB SETTINGS (machine-specific)
WORKTREES_DIR=../myapp-worktrees

# JIRA DEFAULT SETTINGS 
JIRA_ACCOUNT_URL=your-site.atlassian.net
JIRA_ACCOUNT_EMAIL=you@example.com
# the raw API token value itself — not a path to a token file
JIRA_TOKEN=your-api-token-value

# JIRA EXECUTOR WORKER IDENTITY (optional) — a dedicated Jira account that
# owns every issue the skills create and act on. When both are unset/empty,
# the skills fall back to JIRA_ACCOUNT_EMAIL/JIRA_TOKEN above and nothing
# else changes beyond: issues are assigned to that account instead of left
# unassigned. Uncomment + fill to run as a dedicated worker — jira-task-assigner
# then assigns every issue it creates to this email, and jira-task-executor
# re-logs acli in as this identity and refuses to work an issue not assigned
# to it. JIRA_EXECUTOR_TOKEN is the raw API token value itself, not a path to
# a token file — exactly as JIRA_TOKEN above. See skills/_shared/project-config.md
# for the machine-global acli logout side effect, and get_assignee_email.sh /
# executor_identity.sh (the scripts the skills call) under skills/_shared/scripts/.
#JIRA_EXECUTOR_EMAIL=someworker@example.com
#JIRA_EXECUTOR_TOKEN=your-executor-api-token-value


